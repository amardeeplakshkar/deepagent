{
  "name": "@deepagent/openapi-to-ts",
  "version": "8.0.0",
  "description": "Generate an Agentic TypeScript client from an OpenAPI spec.",
  "author": "Amardeep Lakshkar <https://amardeep.space> ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amardeeplakshkar/deepagent.git",
    "directory": "stdlib/openapi-to-ts"
  },
  "type": "module",
  "bin": {
    "openapi-to-ts": "./dist/openapi-to-ts.js"
  },
  "source": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "clean": "del dist",
    "test": "run-s test:*",
    "test:typecheck": "tsc --noEmit",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@agentic/core": "^8.4.4",
    "@apidevtools/swagger-parser": "latest",
    "camelcase": "latest",
    "cleye": "latest",
    "decamelize": "latest",
    "execa": "latest",
    "exit-hook": "latest",
    "json-schema-to-zod": "latest",
    "openapi-types": "latest",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "ky": "^1.10.0",
    "tsup": "^8.5.0",
    "typescript": "5.5.4"
  },
  "publishConfig": {
    "access": "public",
    "files": [
      "dist"
    ],
    "types": "./dist/index.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    }
  }
}
