{
  "name": "@deepagent/github",
  "version": "7.6.9",
  "description": "DeepAgent Agentic SDK for GitHub.",
  "author": "Amardeep Lakshkar <https://amardeep.space> ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amardeeplakshkar/deepagent.git",
    "directory": "stdlib/github"
  },
  "type": "module",
  "sideEffects": false,
  "source": "./src/index.ts",
  "types": "./dist/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "del dist",
    "test": "run-s test:*",
    "test:typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentic/core": "^8.4.4",
    "octokit": "latest"
  },
  "peerDependencies": {
    "zod": "^3.25.67"
  },
  "publishConfig": {
    "access": "public"
  }
}
